    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "framer-motion": "^11.3.30",
    "lucide-react": "^0.436.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "tailwind-merge": "^2.5.2",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.1",
